          <formatted-text>
            <run>Créneaux horaires et jours de la semaine les plus demandés</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='dataset_salons_lovelie' name='federated.0y0h9bw042aifd13r8toy0yhs4ux' />
          </datasources>
          <datasource-dependencies datasource='federated.0y0h9bw042aifd13r8toy0yhs4ux'>
            <column caption='Jour de la semaine' datatype='string' name='[Calculation_0079213486755846]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [date_prestation])' />
            </column>
            <column-instance column='[reservation_id]' derivation='Count' name='[cnt:reservation_id:qk]' pivot='key' type='quantitative' />
            <column-instance column='[reservation_id]' derivation='CountD' name='[ctd:reservation_id:qk]' pivot='key' type='quantitative' />
            <column caption='Date Prestation' datatype='date' name='[date_prestation]' role='dimension' type='ordinal' />
            <column caption='Heure Prestation' datatype='datetime' name='[heure_prestation]' role='dimension' type='ordinal' />
            <column-instance column='[heure_prestation]' derivation='Hour' name='[hr:heure_prestation:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Calculation_0079213486755846]' derivation='None' name='[none:Calculation_0079213486755846:nk]' pivot='key' type='nominal' />
            <column caption='Reservation Id' datatype='string' name='[reservation_id]' role='dimension' type='nominal' />
          </datasource-dependencies>
