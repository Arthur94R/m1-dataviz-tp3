      <aliases enabled='yes' />
      <column caption='Est Annulé/No-show' datatype='integer' name='[Calculation_0079213481771009]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [statut] = &quot;Annulé&quot; OR [statut] = &quot;No-show&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Taux d&apos;annulation (%)' datatype='real' name='[Calculation_0079213482184706]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0079213481771009]) / COUNT([reservation_id]) * 100' />
      </column>
      <column caption='Manque à gagner' datatype='integer' name='[Calculation_0079213482237955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [statut] = &quot;Annulé&quot; OR [statut] = &quot;No-show&quot; THEN [prix_euros] ELSE 0 END' />
      </column>
      <column caption='Est Réalisé' datatype='integer' name='[Calculation_0079213482848260]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [statut] = &quot;Réalisé&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Taux de réalisation (%)' datatype='real' name='[Calculation_0079213483106309]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0079213482848260]) / COUNT([reservation_id]) * 100' />
      </column>
      <column caption='Jour de la semaine' datatype='string' name='[Calculation_0079213486755846]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;weekday&apos;, [date_prestation])' />
      </column>
      <column caption='saison_été' datatype='string' name='[Calculation_0156662121123840]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;month&apos;,[date_prestation]) &gt;= 5 &#10;AND DATEPART(&apos;month&apos;,[date_prestation]) &lt;= 8 &#10;THEN &quot;Mai - Août&quot;&#10;ELSE &quot;Autres mois&quot;&#10;END' />
      </column>
